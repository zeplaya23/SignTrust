# ──────────────────────────────────────────────
# SignTrust — Docker environment variables
# ──────────────────────────────────────────────

# Database (runs inside the existing trust-mysql container)
SIGNTRUST_DB_USER=signtrust
SIGNTRUST_DB_PASSWORD=ChangeMeSignTrustP@ss2024
SIGNTRUST_DB_NAME=signtrust_db

# MinIO (SignTrust dedicated instance)
MINIO_ROOT_USER=signtrust-admin
MINIO_ROOT_PASSWORD=ChangeMeMinioP@ss2024

# Keycloak (existing trust-keycloak — container_name is the DNS on external network)
KEYCLOAK_URL=http://trust-keycloak:8080/auth

# EJBCA PKI (existing trust-ejbca-pki)
EJBCA_URL=https://trust-ejbca-pki:8443

# DSS (existing trust-dss)
DSS_URL=http://trust-dss:8080
