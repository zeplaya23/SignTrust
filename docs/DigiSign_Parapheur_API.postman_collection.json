									"    pm.collectionVariables.set('signatory_id', jsonData.id);",
									"    console.log('signatory_id = ' + jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"signataire@example.com\",\n  \"firstName\": \"Jean\",\n  \"lastName\": \"Dupont\",\n  \"role\": \"SIGNER\",\n  \"orderIndex\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/signatories",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "signatories"]
						},
						"description": "Ajoute un signataire a l'enveloppe. L'ID est automatiquement sauvegarde."
					}
				},
				{
					"name": "Lister les signataires",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/signatories",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "signatories"]
						},
						"description": "Liste les signataires d'une enveloppe."
					}
				},
				{
					"name": "Modifier un signataire",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"nouveau@example.com\",\n  \"firstName\": \"Marie\",\n  \"lastName\": \"Martin\",\n  \"role\": \"SIGNER\",\n  \"orderIndex\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/signatories/{{signatory_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "signatories", "{{signatory_id}}"]
						},
						"description": "Modifie les informations d'un signataire."
					}
				},
				{
					"name": "Supprimer un signataire",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/signatories/{{signatory_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "signatories", "{{signatory_id}}"]
						},
						"description": "Supprime un signataire de l'enveloppe."
					}
				}
			]
		},
		{
			"name": "4. Champs de signature",
			"item": [
				{
					"name": "Ajouter un champ de signature",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.collectionVariables.set('field_id', jsonData.id);",
									"    console.log('field_id = ' + jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"documentId\": {{document_id}},\n  \"signatoryId\": {{signatory_id}},\n  \"type\": \"SIGNATURE\",\n  \"pageNumber\": 1,\n  \"x\": 100.0,\n  \"y\": 650.0,\n  \"width\": 200.0,\n  \"height\": 80.0\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/fields",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "fields"]
						},
						"description": "Positionne un champ de signature sur un document pour un signataire.\n\nTypes : SIGNATURE, INITIALS, DATE, TEXT\n\nCoordonnees en points PDF (72 pts/pouce). x,y partent du coin bas-gauche."
					}
				},
				{
					"name": "Lister les champs",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/fields",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "fields"]
						},
						"description": "Liste tous les champs de signature de l'enveloppe."
					}
				},
				{
					"name": "Modifier un champ",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
