				},
				{
					"name": "Supprimer un champ",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/fields/{{field_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "fields", "{{field_id}}"]
						},
						"description": "Supprime un champ de signature."
					}
				}
			]
		},
