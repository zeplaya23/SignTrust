		{
			"name": "6. Workflow complet",
			"item": [
				{
					"name": "STEP 1 - Creer enveloppe",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('envelope_id', jsonData.id);",
									"pm.test('Enveloppe creee', function() {",
									"    pm.response.to.have.status(201);",
									"    pm.expect(jsonData.status).to.eql('DRAFT');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
