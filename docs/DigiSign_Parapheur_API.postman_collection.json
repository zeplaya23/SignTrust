{
	"info": {
		"_postman_id": "digisign-parapheur-api-keys",
		"name": "DigiSign Parapheur - API Integrateurs",
		"description": "Collection Postman pour les integrateurs utilisant les cles API DigiSign Parapheur.\n\n## Configuration\n1. Definir la variable `base_url` avec l'URL de votre serveur\n2. Definir la variable `api_key` avec votre cle API (dsp_...)\n\n## Workflow\n1. Verifier le statut de l'API\n2. Creer une enveloppe\n3. Ajouter un document PDF\n4. Ajouter un ou plusieurs signataires\n5. Positionner les champs de signature\n6. Envoyer l'enveloppe",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "apikey",
		"apikey": [
			{
				"key": "key",
				"value": "X-API-Key",
				"type": "string"
			},
			{
				"key": "value",
				"value": "{{api_key}}",
				"type": "string"
			},
			{
				"key": "in",
				"value": "header",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://158.220.112.175:5080",
			"type": "string"
		},
		{
			"key": "api_key",
			"value": "dsp_VOTRE_CLE_API_ICI",
			"type": "string"
		},
		{
			"key": "envelope_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "document_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "signatory_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "field_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "0. Statut API",
			"item": [
				{
					"name": "Verifier le statut",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/status",
							"host": ["{{base_url}}"],
							"path": ["api", "status"]
						},
						"description": "Verifie que l'API est disponible. Pas besoin de cle API."
					}
				}
			]
		},
		{
			"name": "1. Enveloppes",
			"item": [
				{
					"name": "Creer une enveloppe",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.collectionVariables.set('envelope_id', jsonData.id);",
									"    console.log('envelope_id = ' + jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Contrat de prestation 2026\",\n  \"message\": \"Merci de bien vouloir signer ce contrat.\",\n  \"signingOrder\": \"PARALLEL\",\n  \"expiresAt\": \"2026-12-31T23:59:59\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/envelopes",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes"]
						},
						"description": "Cree une nouvelle enveloppe en brouillon. L'ID est automatiquement sauvegarde dans la variable `envelope_id`."
					}
				},
				{
					"name": "Lister les enveloppes",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes?page=0&size=20",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes"],
							"query": [
								{
									"key": "page",
									"value": "0"
								},
								{
									"key": "size",
									"value": "20"
								},
								{
									"key": "status",
									"value": "DRAFT",
									"disabled": true
								}
							]
						},
						"description": "Liste les enveloppes du compte. Filtrable par statut : DRAFT, SENT, COMPLETED, CANCELLED."
					}
				},
				{
					"name": "Detail d'une enveloppe",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}"]
						},
						"description": "Retourne le detail complet d'une enveloppe avec documents, signataires, champs et piste d'audit."
					}
				},
				{
					"name": "Modifier une enveloppe",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Contrat modifie\",\n  \"message\": \"Message mis a jour\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}"]
						},
						"description": "Modifie une enveloppe en statut DRAFT."
					}
				},
				{
					"name": "Envoyer l'enveloppe",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/send",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "send"]
						},
						"description": "Envoie l'enveloppe aux signataires. L'enveloppe doit contenir au moins un document et un signataire."
					}
				},
				{
					"name": "Annuler une enveloppe",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/cancel",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "cancel"]
						},
						"description": "Annule une enveloppe en cours."
					}
				},
				{
					"name": "Supprimer une enveloppe",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}"]
						},
						"description": "Supprime une enveloppe en statut DRAFT."
					}
				}
			]
		},
		{
			"name": "2. Documents",
			"item": [
				{
					"name": "Ajouter un document PDF",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.collectionVariables.set('document_id', jsonData.id);",
									"    console.log('document_id = ' + jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"description": "Fichier PDF a signer",
									"type": "file",
									"src": ""
								},
								{
									"key": "name",
									"value": "Contrat principal",
									"description": "Nom du document (optionnel)",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/documents",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "documents"]
						},
						"description": "Ajoute un fichier PDF a l'enveloppe. L'ID du document est automatiquement sauvegarde."
					}
				},
				{
					"name": "Telecharger un document",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/documents/{{document_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "documents", "{{document_id}}"]
						},
						"description": "Telecharge le fichier PDF d'un document."
					}
				},
				{
					"name": "Telecharger tous les documents (ZIP)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/documents/zip",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "documents", "zip"]
						},
						"description": "Telecharge une archive ZIP contenant tous les documents de l'enveloppe."
					}
				},
				{
					"name": "Supprimer un document",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/envelopes/{{envelope_id}}/documents/{{document_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "envelopes", "{{envelope_id}}", "documents", "{{document_id}}"]
						},
						"description": "Supprime un document de l'enveloppe."
					}
				}
			]
		},
		{
			"name": "3. Signataires",
